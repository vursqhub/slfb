local function GetRebirthRewardPart()
    local result = nil
    pcall(function()
        local worldModel = GetGuiPath("HUD","Rebirth","InsiderFrame","Insider","Brainrots","RebirthReward","ViewportFrame","WorldModel")
        if not worldModel then return end
        local rewardModel = worldModel:GetChildren()[1]
        if not rewardModel then return end
        local rewardName = rewardModel.Name
        if not GameFolder then return end
        local brainrotsFolder = GameFolder:FindFirstChild("Brainrots")
        if not brainrotsFolder then return end
        for _, rarity in ipairs(rarityList) do
            local rf = brainrotsFolder:FindFirstChild(rarity)
            if rf then
                local match = rf:FindFirstChild(rewardName)
                if match then
                    local part = match:IsA("BasePart") and match or match:FindFirstChildWhichIsA("BasePart", true)
                    if part then result = part return end
                end
            end
        end
    end)
    return result
end

local function TryRebirth(farmSpeed, cooldownAfterTP, cooldownAfterE, homePosition)
    pcall(function()
        local hud = GetGuiPath("HUD")
        if not hud then return end
        local rewardPart = GetRebirthRewardPart()
        if rewardPart then
            TweenTo(rewardPart.Position + Vector3.new(0, 3, 0), farmSpeed)
            task.wait(cooldownAfterTP)
            SpamInteract(8, 0.05)
            task.wait(cooldownAfterE)
            TweenTo(homePosition, farmSpeed)
            task.wait(0.3)
        end
        local rebirthPopup = hud:FindFirstChild("Rebirth")
        if not rebirthPopup then return end
        local insiderFrame = rebirthPopup:FindFirstChild("InsiderFrame")
        if not insiderFrame then return end
        local confirmBtn = insiderFrame:FindFirstChild("Rebirth")
        if confirmBtn then FireAllButtons(confirmBtn) end
        for _, obj in ipairs(rebirthPopup:GetDescendants()) do
            pcall(function() if obj:IsA("RemoteEvent") then obj:FireServer() end end)
        end
    end)
end

