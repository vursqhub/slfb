local function GetExecutor()
    local name = "Unknown"
    pcall(function()
        -- Most reliable: universal executor-name functions first
        if identifyexecutor then
            name = tostring(identifyexecutor())
        elseif getexecutorname then
            name = tostring(getexecutorname())
        -- Fallback: check known executor globals
        elseif syn and syn.request then
            name = "Synapse X"
        elseif KRNL_LOADED then
            name = "KRNL"
        elseif fluxus and fluxus.request then
            name = "Fluxus"
        elseif electron then
            name = "Electron"
        elseif pebc_loaded then
            name = "Penguinware"
        elseif MACSPLOIT_ALLOWED then
            name = "MacSploit"
        elseif _G.INFINITE_YIELD_LOADED then
            name = "Scriptblox Exec"
        end
    end)
    return name
end

local function GetHWID()
    local id = "Unavailable"
    pcall(function()
        if gethwid then
            id = tostring(gethwid())
        elseif machine_id then
            id = tostring(machine_id())
        end
    end)
    return id
end

local function GetDevice()
    local device = "PC"
    pcall(function()
        if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
            device = "Mobile"
        elseif UserInputService.GamepadEnabled and not UserInputService.KeyboardEnabled then
            device = "Console"
        else
            device = "PC"
        end
    end)
    return device
end

