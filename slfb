-- CROSS-PLATFORM INTERACT
-- ============================================================
local function PressInteract()
    if not isMobile and hasKeypress then
        pcall(function() keypress(0x45); task.wait(0.05); keyrelease(0x45) end)
    end
    if hasFireProximity then
        pcall(function()
            local char = LocalPlayer.Character; if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local pp = obj.Parent
                    if pp and pp:IsA("BasePart") then
                        local d = (hrp.Position - pp.Position).Magnitude
                        if d <= (obj.MaxActivationDistance + 8) then
                            obj.HoldDuration = 0
                            fireproximityprompt(obj)
                        end
                    end
                end
            end
        end)
    end
end

local function SpamInteract(times, interval)
    for _ = 1, (times or 8) do PressInteract(); task.wait(interval or 0.05) end
end

