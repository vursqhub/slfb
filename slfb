local function GetGuiPath(...)
    local current = LocalPlayer:FindFirstChild("PlayerGui")
    if not current then return nil end
    for _, name in ipairs({...}) do
        current = current:FindFirstChild(name)
        if not current then return nil end
    end
    return current
end

local function FireButton(btn)
    if not btn then return end
    pcall(function() firesignal(btn.MouseButton1Click) end)
    task.wait(0.05)
    pcall(function() firesignal(btn.Activated) end)
    task.wait(0.05)
    pcall(function() firesignal(btn.MouseButton1Down, 0, 0) end)
    task.wait(0.02)
    pcall(function() firesignal(btn.MouseButton1Up, 0, 0) end)
    task.wait(0.02)
    pcall(function() btn:SimulateClick() end)
end

local function FireAllButtons(root)
    if not root then return end
    if root:IsA("TextButton") or root:IsA("ImageButton") then FireButton(root) end
    for _, child in ipairs(root:GetDescendants()) do
        if child:IsA("TextButton") or child:IsA("ImageButton") then FireButton(child) end
    end
end

