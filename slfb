        end
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then CreatePlayerESP(player) end
        end
        Players.PlayerAdded:Connect(function(player)
            if not playerESPActive then return end
            player.CharacterAdded:Connect(function() task.wait(1); if playerESPActive then CreatePlayerESP(player) end end)
        end)
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                player.CharacterAdded:Connect(function()
                    task.wait(1); RemovePlayerESP(player)
                    if playerESPActive then CreatePlayerESP(player) end
                end)
            end
        end
        local espRefresh = 0
        playerESPConn = RunService.Heartbeat:Connect(function(dt)
            UpdatePlayerESP()
            espRefresh += dt; if espRefresh < 0.5 then return end; espRefresh = 0
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    local char = player.Character
                    if char then
                        if not playerHighlights[player] or not playerHighlights[player].Parent then
                            RemovePlayerESP(player); CreatePlayerESP(player)
                        end
                    else RemovePlayerESP(player) end
                end
            end
            for player in pairs(playerHighlights) do
                if not player.Parent then RemovePlayerESP(player) end
            end
        end)
    end,
})

