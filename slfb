-- ── Fly ───────────────────────────────────────────────────
MovementTab:CreateSection("Fly")

local flyActive   = false
local flySpeed    = 50
local flyConn     = nil
local flyChar     = nil
local flyHRP      = nil
local flyHum      = nil

-- Clean up any existing fly instances
local function StopFly()
    flyActive = false
    if flyConn then flyConn:Disconnect(); flyConn = nil end
    if flyHRP then
        local bv = flyHRP:FindFirstChild("SLFB_FlyVel")
        if bv then bv:Destroy() end
        local bg = flyHRP:FindFirstChild("SLFB_FlyGyro")
        if bg then bg:Destroy() end
    end
    if flyHum then
        flyHum.PlatformStand = false
    end
    flyHRP = nil
    flyHum = nil
    flyChar = nil
end

local function StartFly()
    flyChar = LocalPlayer.Character
    if not flyChar then return end
    flyHRP  = flyChar:FindFirstChild("HumanoidRootPart")
    flyHum  = flyChar:FindFirstChildOfClass("Humanoid")
    if not flyHRP or not flyHum then return end

    flyActive = true
    flyHum.PlatformStand = true

    -- Create controllers fresh
    local bv = Instance.new("BodyVelocity")
    bv.Name      = "SLFB_FlyVel"
    bv.Velocity  = Vector3.zero
    bv.MaxForce  = Vector3.new(math.huge, math.huge, math.huge)
    bv.P         = 1e4
    bv.Parent    = flyHRP

    local bg = Instance.new("BodyGyro")
    bg.Name       = "SLFB_FlyGyro"
    bg.MaxTorque  = Vector3.new(math.huge, math.huge, math.huge)
    bg.P          = 1e4
    bg.D          = 100
    bg.CFrame     = flyHRP.CFrame
    bg.Parent     = flyHRP

    flyConn = RunService.RenderStepped:Connect(function()
        -- Re-grab in case of respawn
        local char = LocalPlayer.Character
        if not char then StopFly() return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then StopFly() return end

        local cam  = workspace.CurrentCamera
        local vel  = Vector3.zero
        local up   = Vector3.new(0, 1, 0)
        local look = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z).Unit
        local right = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z).Unit

        if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + look end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - look end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - right end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + right end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + up end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel = vel - up end

        local activeVel = hrp:FindFirstChild("SLFB_FlyVel")
        local activeGyro = hrp:FindFirstChild("SLFB_FlyGyro")
        if not activeVel or not activeGyro then StopFly() return end

        if vel.Magnitude > 0 then
            activeVel.Velocity = vel.Unit * flySpeed
        else
            -- Hover in place with damping
            activeVel.Velocity = activeVel.Velocity * 0.75
        end

        -- Smoothly rotate toward movement direction
        if vel.Magnitude > 0 then
            local targetCFrame = CFrame.new(hrp.Position, hrp.Position + vel)
            activeGyro.CFrame = targetCFrame
        else
            activeGyro.CFrame = hrp.CFrame
        end
    end)
end

MovementTab:CreateSlider({
    Name         = "Fly Speed",
    Range        = {10, 300},
    Increment    = 5,
    CurrentValue = 50,
    Flag         = "FlySpeed",
    Callback     = function(val) flySpeed = val end,
})

MovementTab:CreateToggle({
