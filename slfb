MovementTab:CreateSection("Fly")

local flySpeed  = 50
local flyActive = false
local flyConn   = nil
local flyVel    = Vector3.zero

local function StopFly()
    flyActive = false
    if flyConn then flyConn:Disconnect(); flyConn = nil end
    flyVel = Vector3.zero
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hum then hum.PlatformStand = false; hum.AutoRotate = true end
        if hrp then
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end)
end

local function StartFly()
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        flyActive = true
        flyVel    = Vector3.zero
        hum.PlatformStand = true
        hum.AutoRotate    = false
        if flyConn then flyConn:Disconnect() end
        flyConn = RunService.RenderStepped:Connect(function(dt)
            pcall(function()
                local c    = LocalPlayer.Character
                if not c then StopFly() return end
                local root = c:FindFirstChild("HumanoidRootPart")
                local h    = c:FindFirstChildOfClass("Humanoid")
                if not root or not h then StopFly() return end
                h.PlatformStand = true
                h.AutoRotate    = false
                local cam   = workspace.CurrentCamera
                local cf    = cam.CFrame
                local input = Vector3.zero
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then input += cf.LookVector  end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then input -= cf.LookVector  end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then input -= cf.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then input += cf.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then input += Vector3.new(0,1,0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then input -= Vector3.new(0,1,0) end
                if input.Magnitude > 0 then
                    flyVel = flyVel:Lerp(input.Unit * flySpeed, 0.3)
                else
                    flyVel = flyVel:Lerp(Vector3.zero, 0.2)
                end
                root.CFrame = root.CFrame + flyVel * dt
                root.AssemblyLinearVelocity  = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end)
        end)
    end)
end

MovementTab:CreateSlider({
    Name         = "Fly Speed",
    Range        = {10, 1000},
    Increment    = 10,
    CurrentValue = 50,
    Flag         = "FlySpeed",
