local function GetRebirthRewardPart()
    local result = nil
    pcall(function()
        local worldModel = GetGuiPath("HUD","Rebirth","InsiderFrame","Insider","Brainrots","RebirthReward","ViewportFrame","WorldModel")
        if not worldModel then return end
        local rewardModel = worldModel:GetChildren()[1]; if not rewardModel then return end
        local rewardName  = rewardModel.Name
        if not GameFolder then return end
        local bf = GameFolder:FindFirstChild("Brainrots"); if not bf then return end
        for _, rarity in ipairs(rarityList) do
            local rf = bf:FindFirstChild(rarity)
            if rf then
                local match = rf:FindFirstChild(rewardName)
                if match then
                    local part = match:IsA("BasePart") and match or match:FindFirstChildWhichIsA("BasePart", true)
                    if part then result = part return end
                end
            end
        end
    end)
    return result
