local function GetClaimTargets()
    local claims = {}
    pcall(function()
        if not GameFolder then return end
        local plotsFolder = GameFolder:FindFirstChild("Plots")
        if not plotsFolder then return end
        for _, plotIndex in ipairs({"1","2","3","4","5"}) do
            local plot = plotsFolder:FindFirstChild(plotIndex)
            if not plot then continue end
            local brainrotsFolder = plot:FindFirstChild("Brainrots")
            if not brainrotsFolder then continue end
            local brainrotNames = {}
            for _, b in ipairs(brainrotsFolder:GetChildren()) do
                brainrotNames[b.Name] = true
            end
            local placesFolder = plot:FindFirstChild("Places")
            if not placesFolder then continue end
            for _, place in ipairs(placesFolder:GetChildren()) do
                if brainrotNames[place.Name] then
                    local claimObj = place:FindFirstChild("Claim")
                    if claimObj then
                        claims[#claims+1] = claimObj
                    end
                end
            end
        end
    end)
    return claims
end

local function BringClaimToPlayer(claimObj)
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local targetCF = hrp.CFrame + Vector3.new(0, 2, 0)
        if claimObj:IsA("BasePart") then
            claimObj.CFrame = targetCF
        end
        for _, part in ipairs(claimObj:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CFrame = targetCF
            end
        end
        for _, desc in ipairs(claimObj:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                desc.HoldDuration = 0
                pcall(function() fireproximityprompt(desc) end)
            end
        end
        if claimObj:IsA("ProximityPrompt") then
            pcall(function() fireproximityprompt(claimObj) end)
        end
    end)
end

