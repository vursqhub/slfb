-- Player ESP section inside Brainrots tab
BrainrotsTab:CreateSection("Player ESP")
BrainrotsTab:CreateToggle({
    Name         = "Player ESP",
    CurrentValue = false,
    Flag         = "PlayerESP",
    Callback     = function(state)
        playerESPActive = state

        if playerESPConn then playerESPConn:Disconnect(); playerESPConn = nil end

        if not state then
            -- Clean up all ESP
            for player in pairs(playerHighlights) do RemovePlayerESP(player) end
            for player in pairs(playerBillboards)  do RemovePlayerESP(player) end
            return
        end

        -- Build ESP for existing players
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                CreatePlayerESP(player)
            end
        end

        -- Handle new players joining
        Players.PlayerAdded:Connect(function(player)
            if not playerESPActive then return end
            player.CharacterAdded:Connect(function()
                task.wait(1)
                if playerESPActive then CreatePlayerESP(player) end
            end)
        end)

        -- Handle characters respawning
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                player.CharacterAdded:Connect(function()
                    task.wait(1)
                    RemovePlayerESP(player)
                    if playerESPActive then CreatePlayerESP(player) end
                end)
            end
        end

        -- Update loop: refresh ESP + distances every 0.5s
        local timer = 0
        playerESPConn = RunService.Heartbeat:Connect(function(dt)
            timer += dt
            if timer < 0.5 then
                UpdatePlayerESPDistances()
                return
            end
            timer = 0
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    -- Re-create if missing (e.g. after respawn)
                    local char = player.Character
                    if char then
                        if not playerHighlights[player] or not playerHighlights[player].Parent then
                            RemovePlayerESP(player)
                            CreatePlayerESP(player)
                        end
                    else
                        RemovePlayerESP(player)
                    end
                end
            end
            -- Clean up ESP for players who left
            for player in pairs(playerHighlights) do
                if not player.Parent then RemovePlayerESP(player) end
            end
        end)
    end,
})

