                local root = c:FindFirstChild("HumanoidRootPart")
                local h    = c:FindFirstChildOfClass("Humanoid")
                if not root or not h then StopFly() return end
                h.PlatformStand = true; h.AutoRotate = false
                local input = Vector3.zero
                if isMobile then
                    local md = h.MoveDirection
                    if md.Magnitude > 0 then input = Vector3.new(md.X, 0, md.Z) end
                    input += Vector3.new(0, mobileJumpHeld and 1 or -0.3, 0)
                else
                    local cam = workspace.CurrentCamera; local cf = cam.CFrame
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then input += cf.LookVector  end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then input -= cf.LookVector  end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then input -= cf.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then input += cf.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then input += Vector3.new(0,1,0) end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then input -= Vector3.new(0,1,0) end
                end
                flyVel = input.Magnitude > 0 and flyVel:Lerp(input.Unit * flySpeed, 0.3) or flyVel:Lerp(Vector3.zero, 0.2)
                root.CFrame = root.CFrame + flyVel * dt
                root.AssemblyLinearVelocity  = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end)
        end)
    end)
end

MovementTab:CreateSlider({ Name = "Fly Speed", Range = {10,1000}, Increment = 10, CurrentValue = 50, Flag = "FlySpeed", Callback = function(v) flySpeed = v end })
MovementTab:CreateToggle({ Name = "Fly", CurrentValue = false, Flag = "FlyToggle", Callback = function(state) if state then StartFly() else StopFly() end end })

LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1.5)
    EnableInstantPickup()
    if flyActive    then StartFly()      end
    if noclipActive then SetNoclip(true) end
end)

