local function GetBrainrotsInZone(zone)
    local list = {}
    pcall(function()
        if not GameFolder then return end
        local bf = GameFolder:FindFirstChild("Brainrots"); if not bf then return end
        local zf = bf:FindFirstChild(zone); if not zf then return end
        for _, obj in ipairs(zf:GetChildren()) do
            local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart", true)
            if part then list[#list+1] = part end
        end
    end)
    return list
end

local function RunAutofarm()
    while autofarmRunning do
        local brainrots = GetBrainrotsInZone(selectedZone)
        if #brainrots == 0 then
            Rayfield:Notify({ Title = "Autofarm", Content = "No brainrots in "..selectedZone..".", Duration = 3 })
            task.wait(2)
        else
            for _, part in ipairs(brainrots) do
                if not autofarmRunning then break end
                task.wait(cooldownBeforeTP)
                TweenTo(part.Position + Vector3.new(0, aboveDistance, 0), farmSpeed)
                task.wait(cooldownAfterTP)
                SpamInteract(8, 0.05)
                task.wait(cooldownAfterE)
                TweenTo(homePosition, farmSpeed)
                task.wait(cooldownAfterHome)
            end
        end
        task.wait(0.05)
    end
end

