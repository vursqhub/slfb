})

local countTimer = 0
RunService.Heartbeat:Connect(function(dt)
    countTimer = countTimer + dt
    if countTimer < 1 then return end
    countTimer = 0
    local brainrotsFolder = GameFolder:FindFirstChild("Brainrots")
    if not brainrotsFolder then
        countParagraph:Set({ Title = "Brainrots in World", Content = "Brainrots folder not found." })
        return
    end
    local parts = {}
    for _, rarity in ipairs(rarityList) do
        local folder = brainrotsFolder:FindFirstChild(rarity)
        if folder then
            local count = #folder:GetChildren()
            if count > 0 then parts[#parts+1] = rarity .. ": " .. count end
        end
    end
    countParagraph:Set({
        Title   = "Brainrots in World",
        Content = #parts > 0 and table.concat(parts, " | ") or "None found."
    })
end)

-- Brainrot ESP
BrainrotsTab:CreateSection("Brainrot ESP")

for _, rarity in ipairs(rarityList) do
    local tag = rarity:lower()
    BrainrotsTab:CreateToggle({
        Name         = "Show " .. rarity,
        CurrentValue = false,
        Flag         = "ESP_" .. rarity,
        Callback     = function(state)
            if ESPConnections[rarity] then
                ESPConnections[rarity]:Disconnect()
                ESPConnections[rarity] = nil
            end
            ClearESPByTag(tag)
            if state then
                local timer = 0
                ESPConnections[rarity] = RunService.Heartbeat:Connect(function(dt)
                    timer = timer + dt
                    if timer < 0.5 then return end
                    timer = 0
                    ClearESPByTag(tag)
                    local brainrotsFolder = GameFolder:FindFirstChild("Brainrots")
                    if not brainrotsFolder then return end
                    local rarityFolder = brainrotsFolder:FindFirstChild(rarity)
                    if not rarityFolder then return end
                    for _, obj in ipairs(rarityFolder:GetChildren()) do
                        local part = obj:IsA("BasePart") and obj
                            or obj:FindFirstChildWhichIsA("BasePart", true)
                        if part then
                            local key = tag .. "_" .. obj.Name
                            if not ESPBillboards[key] or not ESPBillboards[key].Parent then
                                ESPBillboards[key] = CreateBillboard(part, obj.Name, rarityColors[rarity])
                            end
                        end
                    end
                end)
            end
        end,
    })
end

