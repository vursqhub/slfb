-- ============================================================
-- AUTO CLAIM
-- Base = wherever the player spawned when they FIRST joined.
-- No reset needed — captured once on CharacterAdded.
-- When turned off, all moved claim parts are restored to their
-- original CFrames.
-- ============================================================
local playerBasePlot       = nil   -- set once on first spawn
local claimOriginalCFrames = {}    -- [part instance] = original CFrame

-- Capture base on first character load
local baseDetected = false
local function CaptureBaseOnSpawn(char)
    if baseDetected then return end
    task.spawn(function()
        -- Wait for HRP to settle
        local hrp
        local t = 0
        repeat task.wait(0.1); t += 0.1; hrp = char:FindFirstChild("HumanoidRootPart") until hrp or t >= 5
        if not hrp then return end
        task.wait(1) -- settle

        local spawnPos = hrp.Position
        baseDetected = true

        -- Find closest plot to this spawn
        local function findBase()
            if not GameFolder then return end
            local plotsFolder = GameFolder:FindFirstChild("Plots"); if not plotsFolder then return end
            local closest, closestDist = nil, math.huge
            for _, idx in ipairs({"1","2","3","4","5"}) do
                local plot = plotsFolder:FindFirstChild(idx)
                if plot then
                    local p = plot:IsA("BasePart") and plot or plot:FindFirstChildWhichIsA("BasePart", true)
                    if p then
                        local d = (p.Position - spawnPos).Magnitude
                        if d < closestDist then closestDist = d; closest = plot end
                    end
                end
            end
            playerBasePlot = closest
        end

        findBase()
        if not playerBasePlot then
            -- GameFolder may not be loaded yet — retry
            task.delay(3, findBase)
        end
    end)
end

-- Hook current character if already loaded
if LocalPlayer.Character then
    CaptureBaseOnSpawn(LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(CaptureBaseOnSpawn)

local function GetClaimTargetsAtBase()
    local claims = {}
    if not playerBasePlot then return claims end
    pcall(function()
        local brainrotsFolder = playerBasePlot:FindFirstChild("Brainrots"); if not brainrotsFolder then return end
        local brainrotNames = {}
        for _, b in ipairs(brainrotsFolder:GetChildren()) do brainrotNames[b.Name] = true end
        local placesFolder = playerBasePlot:FindFirstChild("Places"); if not placesFolder then return end
        for _, place in ipairs(placesFolder:GetChildren()) do
            if brainrotNames[place.Name] then
                local claimObj = place:FindFirstChild("Claim")
                if claimObj then claims[#claims+1] = claimObj end
            end
        end
    end)
    return claims
end

local function BringClaimToPlayer(claimObj)
    pcall(function()
        local char = LocalPlayer.Character; if not char then return end
        local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local targetCF = hrp.CFrame + Vector3.new(0, 2, 0)

        local function moveAndStore(part)
            if not claimOriginalCFrames[part] then
                claimOriginalCFrames[part] = part.CFrame
            end
            part.CFrame = targetCF
        end

        if claimObj:IsA("BasePart") then moveAndStore(claimObj) end
        for _, part in ipairs(claimObj:GetDescendants()) do
            if part:IsA("BasePart") then moveAndStore(part) end
        end
        for _, desc in ipairs(claimObj:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                desc.HoldDuration = 0
                if hasFireProximity then pcall(function() fireproximityprompt(desc) end) end
            end
        end
        if claimObj:IsA("ProximityPrompt") then
            if hasFireProximity then pcall(function() fireproximityprompt(claimObj) end) end
        end
    end)
end

local function RestoreClaimPositions()
    for part, cf in pairs(claimOriginalCFrames) do
        pcall(function()
            if part and part.Parent then part.CFrame = cf end
        end)
    end
    claimOriginalCFrames = {}
end

