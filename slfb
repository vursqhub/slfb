-- ── Auto Coin ─────────────────────────────────────────────
AutofarmTab:CreateSection("Auto Coin")
AutofarmTab:CreateSlider({
    Name = "Coin Tween Speed", Range = {10, 1000}, Increment = 10, CurrentValue = 100, Flag = "CoinSpeed",
    Callback = function(val) autoCoinSpeed = val end,
})
AutofarmTab:CreateToggle({
    Name         = "Auto Coin",
    CurrentValue = false,
    Flag         = "AutoCoin",
    Callback     = function(state)
        autoCoinRunning = state
        if autoCoinThread then task.cancel(autoCoinThread); autoCoinThread = nil end
        if state then
            autoCoinThread = task.spawn(function()
                while autoCoinRunning do
                    pcall(function()
                        -- Collect all BaseParts/Models named "Coin" in workspace
                        local coins = {}
                        for _, obj in ipairs(workspace:GetDescendants()) do
                            if obj.Name == "Coin" then
                                local part = obj:IsA("BasePart") and obj
                                    or obj:FindFirstChildWhichIsA("BasePart", true)
                                if part then coins[#coins+1] = part end
                            end
                        end

                        if #coins == 0 then
                            task.wait(1)
                            return
                        end

                        for _, part in ipairs(coins) do
                            if not autoCoinRunning then break end
                            if not part or not part.Parent then continue end
                            TweenTo(part.Position + Vector3.new(0, 2, 0), autoCoinSpeed)
                            task.wait(0.15)
                            -- Fire any ProximityPrompts on the coin
                            if hasFireProximity then
                                for _, desc in ipairs(part.Parent:GetDescendants()) do
                                    if desc:IsA("ProximityPrompt") then
                                        desc.HoldDuration = 0
                                        pcall(function() fireproximityprompt(desc) end)
                                    end
                                end
                            end
                            PressInteract()
                            task.wait(0.1)
                        end
                    end)
                    task.wait(0.1)
                end
            end)
            Rayfield:Notify({ Title = "Auto Coin", Content = "Started.", Duration = 3 })
        else
            Rayfield:Notify({ Title = "Auto Coin", Content = "Stopped.", Duration = 3 })
        end
    end,
})

