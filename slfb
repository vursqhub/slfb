local playerESPActive  = false
local playerESPConn    = nil
local playerHighlights = {}
local playerBillboards = {}

local function RemovePlayerESP(player)
    pcall(function()
        if playerHighlights[player] then playerHighlights[player]:Destroy(); playerHighlights[player] = nil end
        if playerBillboards[player]  then playerBillboards[player]:Destroy();  playerBillboards[player]  = nil end
    end)
end

local function CreatePlayerESP(player)
    pcall(function()
        if player == LocalPlayer then return end
        local char = player.Character; if not char then return end
        local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end

        if not playerHighlights[player] or not playerHighlights[player].Parent then
            local hl = Instance.new("Highlight")
            hl.FillColor           = Color3.fromRGB(255, 50, 50)
            hl.OutlineColor        = Color3.fromRGB(255, 255, 255)
            hl.FillTransparency    = 0.5
            hl.OutlineTransparency = 0
            hl.Adornee             = char
            hl.Parent              = char
            playerHighlights[player] = hl
        end

        if not playerBillboards[player] or not playerBillboards[player].Parent then
            local bb = Instance.new("BillboardGui")
            bb.AlwaysOnTop = true
            bb.Size        = UDim2.new(0, 160, 0, 44)
            bb.StudsOffset = Vector3.new(0, 3.5, 0)
            bb.Adornee     = hrp
            bb.Parent      = hrp

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Name                   = "NameLabel"
            nameLbl.Size                   = UDim2.new(1, 0, 0.55, 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text                   = player.DisplayName
            nameLbl.TextColor3             = Color3.fromRGB(255, 80, 80)
            nameLbl.TextStrokeTransparency = 0
            nameLbl.TextScaled             = false
            nameLbl.TextSize               = 16
            nameLbl.Font                   = Enum.Font.GothamBold
            nameLbl.Parent                 = bb

            local distLbl = Instance.new("TextLabel")
            distLbl.Name                   = "DistLabel"
            distLbl.Size                   = UDim2.new(1, 0, 0.45, 0)
            distLbl.Position               = UDim2.new(0, 0, 0.55, 0)
            distLbl.BackgroundTransparency = 1
            distLbl.Text                   = "0 studs"
            distLbl.TextColor3             = Color3.fromRGB(255, 255, 255)
            distLbl.TextStrokeTransparency = 0
            distLbl.TextScaled             = false
            distLbl.TextSize               = 13
            distLbl.Font                   = Enum.Font.Gotham
            distLbl.Parent                 = bb

            playerBillboards[player] = bb
        end
    end)
end

local function UpdatePlayerESP()
    local myChar = LocalPlayer.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    for player, bb in pairs(playerBillboards) do
        pcall(function()
            if not bb or not bb.Parent then return end
            local theirChar = player.Character
            local theirHRP  = theirChar and theirChar:FindFirstChild("HumanoidRootPart")
            if not theirHRP then return end
            local dist    = math.max(1, math.floor((myHRP.Position - theirHRP.Position).Magnitude))
            local distLbl = bb:FindFirstChild("DistLabel")
            local nameLbl = bb:FindFirstChild("NameLabel")
            if distLbl then distLbl.Text = dist.." studs" end
            local textSize = math.clamp(math.floor(110 / dist * 1.5), 7, 24)
            if nameLbl then nameLbl.TextSize = textSize + 3 end
            if distLbl then distLbl.TextSize = textSize end
        end)
    end
end

