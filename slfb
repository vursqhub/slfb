-- ============================================================
-- AUTO CLAIM HELPERS
-- Respawn → detect base spawn position → claim from there only
-- ============================================================
local playerBasePosition = nil  -- set once on first enable

local function DetectPlayerBase()
    -- Respawn the character
    LocalPlayer:LoadCharacter()
    -- Wait for new character and HRP to exist and settle
    task.wait(3)
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            playerBasePosition = hrp.Position
        end
    end)
end

local function GetClaimTargetsAtBase()
    local claims = {}
    if not playerBasePosition then return claims end
    pcall(function()
        if not GameFolder then return end
        local plotsFolder = GameFolder:FindFirstChild("Plots")
        if not plotsFolder then return end

        -- Find the plot closest to the player's base spawn
        local closestPlot = nil
        local closestDist = math.huge
        for _, plotIndex in ipairs({"1","2","3","4","5"}) do
            local plot = plotsFolder:FindFirstChild(plotIndex)
            if plot then
                local part = plot:IsA("BasePart") and plot or plot:FindFirstChildWhichIsA("BasePart", true)
                if part then
                    local d = (part.Position - playerBasePosition).Magnitude
                    if d < closestDist then
                        closestDist = d
                        closestPlot = plot
                    end
                end
            end
        end

        if not closestPlot then return end

        -- Get brainrot names from this plot only
        local brainrotsFolder = closestPlot:FindFirstChild("Brainrots")
        if not brainrotsFolder then return end
        local brainrotNames = {}
        for _, b in ipairs(brainrotsFolder:GetChildren()) do
            brainrotNames[b.Name] = true
        end

        -- Get matched Claim objects from Places
        local placesFolder = closestPlot:FindFirstChild("Places")
        if not placesFolder then return end
        for _, place in ipairs(placesFolder:GetChildren()) do
            if brainrotNames[place.Name] then
                local claimObj = place:FindFirstChild("Claim")
                if claimObj then claims[#claims+1] = claimObj end
            end
        end
    end)
    return claims
end

local function BringClaimToPlayer(claimObj)
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local targetCF = hrp.CFrame + Vector3.new(0, 2, 0)
        if claimObj:IsA("BasePart") then claimObj.CFrame = targetCF end
        for _, part in ipairs(claimObj:GetDescendants()) do
            if part:IsA("BasePart") then part.CFrame = targetCF end
        end
        for _, desc in ipairs(claimObj:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                desc.HoldDuration = 0
                if hasFireProximity then pcall(function() fireproximityprompt(desc) end) end
            end
        end
        if claimObj:IsA("ProximityPrompt") then
            if hasFireProximity then pcall(function() fireproximityprompt(claimObj) end) end
        end
    end)
end

