-- ESP
-- ============================================================
local ESPConnections = {}
local ESPBillboards  = {}

local function ClearESPByTag(tag)
    for key, bb in pairs(ESPBillboards) do
        if string.find(key, tag, 1, true) then
            if bb and bb.Parent then pcall(function() bb:Destroy() end) end
            ESPBillboards[key] = nil
        end
    end
end

local function CreateBillboard(adornee, text, color)
    local ok, result = pcall(function()
        local bb    = Instance.new("BillboardGui")
        bb.AlwaysOnTop = true
        bb.Size        = UDim2.new(0, 140, 0, 35)
        bb.StudsOffset = Vector3.new(0, 4, 0)
        bb.Adornee     = adornee
        bb.Parent      = adornee
        local label = Instance.new("TextLabel")
        label.Size                   = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text                   = text
        label.TextColor3             = color or Color3.fromRGB(255,255,255)
        label.TextStrokeTransparency = 0
        label.TextScaled             = true
        label.Font                   = Enum.Font.GothamBold
        label.Parent                 = bb
        return bb
    end)
    return ok and result or nil
end

-- ============================================================
-- TWEEN HELPER
-- ============================================================
local function TweenTo(targetPos, speed)
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local dist = (hrp.Position - targetPos).Magnitude
        local dur  = math.clamp(dist / math.max(speed, 1), 0.02, 10)
        local tw   = TweenService:Create(
            hrp,
            TweenInfo.new(dur, Enum.EasingStyle.Linear),
            { CFrame = CFrame.new(targetPos) }
        )
        tw:Play()
        tw.Completed:Wait()
    end)
end

-- ============================================================
-- CROSS-PLATFORM INTERACT
-- ============================================================
local function PressInteract()
    if isPC and hasKeypress then
        pcall(function() keypress(0x45); task.wait(0.05); keyrelease(0x45) end)
    end
    if hasFireProximity then
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local pp = obj.Parent
                    if pp and pp:IsA("BasePart") then
                        local dist = (hrp.Position - pp.Position).Magnitude
                        if dist <= (obj.MaxActivationDistance + 8) then
                            obj.HoldDuration = 0
                            fireproximityprompt(obj)
                        end
                    end
                end
            end
        end)
    end
end

local function SpamInteract(times, interval)
    for _ = 1, (times or 8) do
        PressInteract()
        task.wait(interval or 0.05)
    end
end

